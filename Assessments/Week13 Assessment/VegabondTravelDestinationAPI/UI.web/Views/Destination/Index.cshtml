@model IEnumerable<Destination>

<!DOCTYPE html>

<html>
<head>
    <title>Travel Destinations</title>

    ```
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>

        body {
            font-family: 'Poppins',sans-serif;
            background: #f4f6fb;
        }

        /* Header */
        .header {
            background: linear-gradient(135deg,#4facfe,#00f2fe);
            padding: 50px;
            text-align: center;
            color: white;
            margin-bottom: 40px;
        }

            .header h1 {
                font-weight: 700;
            }

        /* Card Styling */

        .card {
            border: none;
            border-radius: 18px;
            transition: 0.3s;
        }

            .card:hover {
                transform: translateY(-6px);
                box-shadow: 0 12px 25px rgba(0,0,0,0.1);
            }

        .city {
            font-size: 22px;
            font-weight: 600;
        }

        .country {
            color: #6c757d;
            font-size: 15px;
        }

        .rating {
            font-weight: 600;
            color: #f39c12;
        }

        .description {
            font-size: 14px;
            color: #6c757d;
        }

    </style>
    ```

</head>

<body>

    ```
    <div class="header">
        <h1>🌍 Travel Destinations</h1>
        <p>Explore the most beautiful cities around the world</p>
    </div>

    <div class="container">

        <div class="row">

            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4">

                    <div class="card shadow-sm p-4">

                        <h5 class="city text-primary">
                            <i class="bi bi-geo-alt-fill"></i> @item.CityName
                        </h5>

                        <p class="country">
                            <i class="bi bi-globe"></i> @item.Country
                        </p>

                        <p class="rating">
                            ⭐ Rating: @item.Rating
                        </p>

                        @if (!string.IsNullOrEmpty(item.Description))
                        {
                            <p class="description">
                                @item.Description
                            </p>
                        }

                    </div>

                </div>
            }

        </div>

    </div>
    ```

</body>
</html>
