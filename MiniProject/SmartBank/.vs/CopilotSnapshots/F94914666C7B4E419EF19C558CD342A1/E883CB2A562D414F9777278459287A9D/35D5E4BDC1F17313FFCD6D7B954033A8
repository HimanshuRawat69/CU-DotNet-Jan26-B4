@{
    ViewData["Title"] = "Home Page";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f5f7fa;
        margin: 0;
        padding: 0;
    }

    .hero {
        background: linear-gradient(135deg, #6a11cb, #2575fc);
        color: white;
        min-height: 60vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 2rem;
        border-radius: 0 0 50px 50px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        animation: fadeIn 1s ease-in-out;
    }

        .hero h1 {
            font-size: 3rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .hero p {
            font-size: 1.2rem;
        }

    .btn-hero {
        background: white;
        color: #2575fc;
        font-weight: bold;
        border-radius: 50px;
        padding: 0.75rem 2rem;
        transition: 0.3s;
        margin-top: 1rem;
    }

        .btn-hero:hover {
            opacity: 0.9;
            color: #6a11cb;
        }

    .features {
        margin-top: -50px;
        padding: 3rem 1rem;
    }

    .feature-card {
        border-radius: 15px;
        padding: 2rem;
        background: white;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        transition: transform 0.3s;
    }

        .feature-card:hover {
            transform: translateY(-10px);
        }

    @@keyframes fadeIn {
        0% {
            opacity: 0;
            transform: translateY(-20px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<!-- Hero Section -->
<div class="hero">
    <h1>Welcome to SmartBank</h1>
    <p>Your trusted partner in banking, loans, and secure transactions.</p>
    <a href="/Auth/Login" class="btn btn-hero">Get Started</a>
</div>

<!-- Features Section -->
<div class="container features">
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="feature-card">
                <h3>Secure Transactions</h3>
                <p>All your transactions are encrypted and protected 24/7 with our advanced security system.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <h3>Quick Account Management</h3>
                <p>View balances, transfer funds, and manage your accounts quickly from any device.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <h3>Customer Support</h3>
                <p>Our dedicated support team is available 24/7 to assist you with all your banking needs.</p>
            </div>
        </div>
    </div>
</div>

<!-- Call to Action -->
<div class="container text-center my-5">
    <h2>Ready to experience smart banking?</h2>
    <a href="/Auth/Register" class="btn btn-primary btn-lg mt-3" style="border-radius:50px;">Create an Account</a>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>