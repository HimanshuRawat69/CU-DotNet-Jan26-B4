html {
  font-size: 14px;
}

@media (min-width: 768px) {
  html {
    font-size: 16px;
  }
}

.btn:focus, .btn:active:focus, .btn-link.nav-link:focus, .form-control:focus, .form-check-input:focus {
  box-shadow: 0 0 0 0.1rem rgba(0,0,0,0.06), 0 0 0 0.25rem rgba(30,144,255,0.18);
}

html {
  position: relative;
  min-height: 100%;
}

body {
  margin-bottom: 80px;
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  background: linear-gradient(180deg, #f6f9ff 0%, #ffffff 100%);
  color: #1f2937;
}

/* New SmartBank Color Palette */
:root {
  --primary-color: #0ea5e9; /* cyan */
  --secondary-color: #6366f1; /* indigo */
  --brand-dark: #0f172a; /* dark */
  --muted: #6b7280;
  --success-color: #10b981;
  --danger-color: #ef4444;
}

/* Navbar */
.navbar-custom {
  background: linear-gradient(90deg, var(--secondary-color), var(--primary-color));
  box-shadow: 0 6px 18px rgba(99,102,241,0.12);
}

.navbar-custom .navbar-brand {
  font-size: 1.4rem;
  font-weight: 800;
  color: #fff !important;
}

.navbar-custom .nav-link {
  color: rgba(255,255,255,0.92) !important;
  transition: color 0.15s ease, transform 0.15s ease;
}

.navbar-custom .nav-link:hover {
  color: #fff !important;
  transform: translateY(-1px);
}

.nav-accent {
  height: 4px;
  background: linear-gradient(90deg, rgba(99,102,241,0.95), rgba(14,165,233,0.95));
}

/* Brand gradient text for small logo accent */
.brand-gradient {
  background: linear-gradient(90deg, #ffffff, rgba(255,255,255,0.8));
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

/* Cards */
.card {
  transition: transform 0.25s, box-shadow 0.25s;
  border-radius: 12px;
  border: 0;
  background: #fff;
}

.card:hover {
  transform: translateY(-6px);
  box-shadow: 0 12px 30px rgba(19,24,44,0.08);
}

/* Buttons */
.btn-primary {
  background: linear-gradient(90deg, var(--secondary-color), var(--primary-color));
  border: none;
  border-radius: 8px;
  padding: 8px 16px;
  box-shadow: 0 6px 18px rgba(14,165,233,0.12);
  transition: transform 0.12s ease, box-shadow 0.12s ease, opacity 0.12s ease;
}

.btn-primary:hover {
  transform: translateY(-2px);
  opacity: 0.98;
}

.btn-outline-custom {
  border-radius: 8px;
  border: 1px solid rgba(15,23,42,0.06);
}

/* Forms */
.form-control {
  border-radius: 10px;
  border: 1px solid #e6eefb;
  padding: 12px 14px;
  background: #fff;
}

.form-control:focus {
  border-color: var(--primary-color);
  box-shadow: 0 6px 18px rgba(14,165,233,0.12);
}

.alert {
  border-radius: 10px;
  border: none;
}

/* Footer */
.footer {
  position: absolute;
  bottom: 0;
  width: 100%;
  line-height: 70px;
  background-color: var(--brand-dark);
  color: rgba(255,255,255,0.85);
}

.footer a { color: rgba(255,255,255,0.9); }

/* Hero / Page header */
.site-hero {
  background: linear-gradient(180deg, rgba(99,102,241,0.06), rgba(14,165,233,0.02));
  border-radius: 10px;
  padding: 18px 22px;
  margin-bottom: 20px;
}

.site-title {
  color: var(--brand-dark);
  font-weight: 700;
}

.fade-in {
  animation: fadeIn 0.5s ease-in-out;
}

/* Loading animation */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Responsive utilities */
@media (max-width: 768px) {
  .navbar-brand {
    font-size: 1.1rem;
  }
  .card {
    margin-bottom: 1rem;
  }
  .footer { line-height: 56px; }
}

/* Accessibility helpers */
.sr-only { position: absolute !important; height: 1px; width: 1px; overflow: hidden; clip: rect(1px, 1px, 1px, 1px); white-space: nowrap; }