@{
    ViewData["Title"] = "Home Page";
}

<div class="site-hero fade-in">
    <div class="container text-center py-5">
        <h1 class="display-5">Welcome to SmartBank</h1>
        <p class="lead">Your trusted partner in banking, loans, and secure transactions.</p>
        <a href="/Auth/Login" class="btn btn-outline-custom btn-lg mt-3">Get Started</a>
    </div>
</div>

<div class="container mt-4">
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card h-100 p-4">
                <i class="bi bi-shield-lock" style="font-size:2rem; color:var(--secondary-color)"></i>
                <h3 class="mt-3">Secure Transactions</h3>
                <p class="text-muted">All your transactions are encrypted and protected 24/7 with our advanced security system.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-4">
                <i class="bi bi-speedometer2" style="font-size:2rem; color:var(--secondary-color)"></i>
                <h3 class="mt-3">Quick Account Management</h3>
                <p class="text-muted">View balances, transfer funds, and manage your accounts quickly from any device.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-4">
                <i class="bi bi-headset" style="font-size:2rem; color:var(--secondary-color)"></i>
                <h3 class="mt-3">Customer Support</h3>
                <p class="text-muted">Our dedicated support team is available 24/7 to assist you with all your banking needs.</p>
            </div>
        </div>
    </div>

    <div class="text-center my-5">
        <h2>Ready to experience smart banking?</h2>
        <a href="/Auth/Register" class="btn btn-primary btn-lg mt-3" style="border-radius:50px;">Create an Account</a>
    </div>
</div>