@model List<SmartBank.Web.Models.AccountViewModel>
@{
    ViewData["Title"] = "My Accounts";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .dashboard-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 40px 0;
        margin: -20px -15px 30px -15px;
        border-radius: 0 0 20px 20px;
    }

    .account-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        margin-bottom: 20px;
        overflow: hidden;
    }

    .account-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    .account-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 20px;
    }

    .balance-display {
        font-size: 2.5rem;
        font-weight: 700;
    }

    .account-number {
        font-family: 'Courier New', monospace;
        letter-spacing: 2px;
        opacity: 0.9;
    }

    .btn-action {
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-deposit {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        border: none;
        color: white;
    }

    .btn-deposit:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(56, 239, 125, 0.3);
        color: white;
    }

    .btn-withdraw {
        background: linear-gradient(135deg, #eb3349 0%, #f45c43 100%);
        border: none;
        color: white;
    }

    .btn-withdraw:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(235, 51, 73, 0.3);
        color: white;
    }

    .stats-card {
        background: white;
        border-radius: 15px;
        padding: 25px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        margin-bottom: 20px;
    }

    .stats-icon {
        font-size: 3rem;
        margin-bottom: 10px;
    }

    .stats-value {
        font-size: 2rem;
        font-weight: 700;
        margin: 10px 0;
    }

    .modal-content {
        border-radius: 15px;
        border: none;
    }

    .modal-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 15px 15px 0 0;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }

    .empty-state i {
        font-size: 5rem;
        color: #667eea;
        opacity: 0.5;
    }
</style>

<div class="dashboard-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1><i class="bi bi-bank2"></i> SmartBank Dashboard</h1>
                <p class="mb-0">Manage your accounts and transactions</p>
            </div>
            <div class="col-md-4 text-end">
                <form method="post" asp-action="Create" style="display: inline;">
                    <button type="submit" class="btn btn-light btn-lg">
                        <i class="bi bi-plus-circle"></i> Create New Account
                    </button>
                </form>
                <a href="/Auth/Logout" class="btn btn-outline-light ms-2">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h3 class="mt-4">No Accounts Yet</h3>
            <p class="text-muted">Create your first bank account to get started with SmartBank!</p>
            <form method="post" asp-action="Create" class="mt-4">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-circle"></i> Create Your First Account
                </button>
            </form>
        </div>
    }
    else
    {
        <!-- Statistics Row -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="stats-card">
                    <i class="bi bi-wallet2 stats-icon text-primary"></i>
                    <h5>Total Accounts</h5>
                    <div class="stats-value text-primary">@Model.Count</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card">
                    <i class="bi bi-cash-stack stats-icon text-success"></i>
                    <h5>Total Balance</h5>
                    <div class="stats-value text-success">₹@Model.Sum(a => a.Balance).ToString("N2")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card">
                    <i class="bi bi-clock-history stats-icon text-info"></i>
                    <h5>Active Since</h5>
                    <div class="stats-value text-info" style="font-size: 1.3rem;">
                        @Model.Min(a => a.CreatedAt).ToString("MMM yyyy")
                    </div>
                </div>
            </div>
        </div>

        <!-- Accounts List -->
        <h3 class="mb-4"><i class="bi bi-credit-card"></i> Your Accounts</h3>
        <div class="row">
            @foreach (var account in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="account-card">
                        <div class="account-header">
                            <h5 class="mb-1"><i class="bi bi-bank"></i> Savings Account</h5>
                            <p class="account-number mb-0">@account.AccountNumber</p>
                        </div>
                        <div class="card-body">
                            <div class="balance-display text-center mb-3">
                                ₹@account.Balance.ToString("N2")
                            </div>
                            <div class="d-grid gap-2">
                                <button class="btn btn-deposit btn-action" onclick="openDepositModal(@account.Id, '@account.AccountNumber')">
                                    <i class="bi bi-arrow-down-circle"></i> Deposit
                                </button>
                                <button class="btn btn-withdraw btn-action" onclick="openWithdrawModal(@account.Id, '@account.AccountNumber', @account.Balance)">
                                    <i class="bi bi-arrow-up-circle"></i> Withdraw
                                </button>
                            </div>
                            <div class="text-center mt-3">
                                <small class="text-muted">
                                    <i class="bi bi-calendar"></i> Created: @account.CreatedAt.ToString("MMM dd, yyyy")
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Deposit Modal -->
<div class="modal fade" id="depositModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-arrow-down-circle"></i> Deposit Money</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Account Number</label>
                    <input type="text" class="form-control" id="depositAccountNumber" readonly>
                </div>
                <div class="mb-3">
                    <label class="form-label">Amount</label>
                    <div class="input-group">
                        <span class="input-group-text">₹</span>
                        <input type="number" class="form-control" id="depositAmount" min="1" step="0.01" placeholder="0.00">
                    </div>
                </div>
                <div id="depositMessage"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-deposit" onclick="submitDeposit()">
                    <i class="bi bi-check-circle"></i> Confirm Deposit
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Withdraw Modal -->
<div class="modal fade" id="withdrawModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-arrow-up-circle"></i> Withdraw Money</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Account Number</label>
                    <input type="text" class="form-control" id="withdrawAccountNumber" readonly>
                </div>
                <div class="mb-3">
                    <label class="form-label">Available Balance</label>
                    <input type="text" class="form-control" id="withdrawAvailableBalance" readonly>
                </div>
                <div class="mb-3">
                    <label class="form-label">Amount</label>
                    <div class="input-group">
                        <span class="input-group-text">₹</span>
                        <input type="number" class="form-control" id="withdrawAmount" min="1" step="0.01" placeholder="0.00">
                    </div>
                </div>
                <div id="withdrawMessage"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-withdraw" onclick="submitWithdraw()">
                    <i class="bi bi-check-circle"></i> Confirm Withdrawal
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentAccountId = 0;
        let maxBalance = 0;

        function openDepositModal(accountId, accountNumber) {
            console.log('openDepositModal called with accountId:', accountId, 'accountNumber:', accountNumber);
            currentAccountId = accountId;
            console.log('currentAccountId set to:', currentAccountId);
            document.getElementById('depositAccountNumber').value = accountNumber;
            document.getElementById('depositAmount').value = '';
            document.getElementById('depositMessage').innerHTML = '';
            new bootstrap.Modal(document.getElementById('depositModal')).show();
        }

        function openWithdrawModal(accountId, accountNumber, balance) {
            currentAccountId = accountId;
            maxBalance = balance;
            document.getElementById('withdrawAccountNumber').value = accountNumber;
            document.getElementById('withdrawAvailableBalance').value = '₹' + balance.toFixed(2);
            document.getElementById('withdrawAmount').value = '';
            document.getElementById('withdrawMessage').innerHTML = '';
            new bootstrap.Modal(document.getElementById('withdrawModal')).show();
        }

        async function submitDeposit() {
            const amount = parseFloat(document.getElementById('depositAmount').value);
            
            if (!amount || amount <= 0) {
                showMessage('depositMessage', 'Please enter a valid amount', 'danger');
                return;
            }

            console.log('Submitting deposit - AccountId:', currentAccountId, 'Amount:', amount);

            try {
                const requestData = {
                    accountId: currentAccountId,
                    amount: amount
                };
                console.log('Request body:', JSON.stringify(requestData));

                const response = await fetch('/Account/Deposit', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(requestData)
                });

                const result = await response.json();

                if (result.success) {
                    showMessage('depositMessage', result.message, 'success');
                    setTimeout(() => {
                        location.reload();
                    }, 1500);
                } else {
                    showMessage('depositMessage', result.message, 'danger');
                }
            } catch (error) {
                showMessage('depositMessage', 'An error occurred', 'danger');
            }
        }

        async function submitWithdraw() {
            const amount = parseFloat(document.getElementById('withdrawAmount').value);
            
            if (!amount || amount <= 0) {
                showMessage('withdrawMessage', 'Please enter a valid amount', 'danger');
                return;
            }

            if (amount > maxBalance) {
                showMessage('withdrawMessage', 'Insufficient balance', 'danger');
                return;
            }

            try {
                const response = await fetch('/Account/Withdraw', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        accountId: currentAccountId,
                        amount: amount
                    })
                });

                const result = await response.json();

                if (result.success) {
                    showMessage('withdrawMessage', result.message, 'success');
                    setTimeout(() => {
                        location.reload();
                    }, 1500);
                } else {
                    showMessage('withdrawMessage', result.message, 'danger');
                }
            } catch (error) {
                showMessage('withdrawMessage', 'An error occurred', 'danger');
            }
        }

        function showMessage(elementId, message, type) {
            const messageDiv = document.getElementById(elementId);
            messageDiv.innerHTML = `<div class="alert alert-${type}">${message}</div>`;
        }
    </script>
}
